# Public site origin (used in OG tags, share URLs, redirect targets)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required) — copy from `npx supabase status` or the hosted project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (required) — S3-compatible storage for challenge images
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public CDN base URL for images, e.g. https://cdn.geoleague.it
NEXT_PUBLIC_R2_PUBLIC_URL=

# Vercel cron auth — generated value, e.g. `openssl rand -hex 32`. The same
# secret is configured in Vercel as the Authorization Bearer for every cron
# hit. Without it the cron route returns 401.
CRON_SECRET=

# Web Push VAPID keys. Generate once via `npx tsx scripts/generate-vapid.ts`.
# Public half also goes into NEXT_PUBLIC_VAPID_PUBLIC_KEY (browser-side).
# VAPID_SUBJECT must be `mailto:you@example.com` or an `https://` URL.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Resend transactional email. RESEND_API_KEY from https://resend.com/api-keys.
# EMAIL_FROM is the "From" header, name + address pair, e.g.
#   "GeoLeague <no-reply@geoleague.it>". Domain must be verified in Resend.
# EMAIL_REPLY_TO is optional; replies bounce to From when unset.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_REPLY_TO=

# Filled in as features land. Add the variable here AND extend src/lib/env.ts.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_PRO_MONTHLY=
# Google Street View Static API key (local fetch-streetview.ts script only — never deployed)
# GOOGLE_MAPS_API_KEY=
